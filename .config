# 1. 硬件锁定 (小米 AX3000T V1)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t=y

# 2. 闭源驱动专属无线面板 (硬件加速已交由底层原生接管，去除了有冲突的turboacc)
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y

# 3. 你的专属翻墙与网络增强
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-mwan3=y

# 4. 续命神药与系统工具 (Zram是 256M 内存刚需)
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_luci-app-zram=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-ramfree=y

# 5. 界面主题与语言包底座 (防止极简编译丢失中文)
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
